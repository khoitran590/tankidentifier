{
  "name": "tankidentifier",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "setup:python": "python -m pip install -r requirements.txt",
    "prepare-data": "npm run setup:python && python scripts/prepare_dataset.py",
